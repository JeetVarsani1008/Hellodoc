@{    Layout = "~/Views/Shared/_LayoutMainAdminDashboard.cshtml";}<head>    <style>        .form-floating > .form-select{        padding-top: 0.8rem;        padding-bottom: 0.625rem;        }    </style>
</head><form method="post" enctype="multipart/form-data">    <div class="profile-main bg-light">        <div class="container pb-4">              <div class="form-profile ">                <div class="d-flex">                <h4 class="m-4 pt-3">Send Orders</h4>                    <a asp-controller="Admin" asp-action="AdminDashboard" class="btn">                        <span class="border border-info text-info p-2 rounded-2">                            < Back                        </span>                    </a>                </div>                <div class="bg-white pt-5">                    <div class="row pb-4 px-4">                        <div class="form-floating mb-3 col-md-6 col-sm-12">                            <select class="form-select" id="physicianSelect" aria-label="Floating label select example">                                <option selected>Select Profession</option>                                <option>Select 1</option>                                <option>Select 2</option>                                <option>Select 3</option>                            </select>                        </div>                        <div class="form-floating mb-3 col-md-6 col-sm-12">                            <input type="text" class="form-control" id="floatingPassword" placeholder="Business">                            <label for="floatingInput" style="margin-left: 1em">Business</label>                        </div>                        <div class="form-floating mb-3 col-md-6 col-sm-12">                            <input type="text" class="form-control" id="floatingPassword" placeholder="Business Contact">                            <label for="floatingInput" style="margin-left: 1em">Business Contact</label>                        </div>                        <div class="form-floating mb-3 col-md-6 col-sm-12">                            <input type="email" class="form-control" id="floatingPassword" placeholder="Email">                            <label for="floatingInput" style="margin-left: 1em">Email</label>                        </div>                        <div class="form-floating mb-3 col-md-6 col-sm-12">                            <input type="text" class="form-control" id="floatingPassword" placeholder="Fax Number">                            <label for="floatingInput" style="margin-left: 1em">Fax Number</label>                        </div>                        <div class=" col-12 form-floating mb-3 ">                           <textarea class="form-control h-100 dclass" id="floatingInput" placeholder=" " rows="5"></textarea>                           <label for="floatingInput" class="text-wrap ms-2 floating-label">Prescription or Order details</label>                        </div>                        <div class="form-floating mb-3 col-md-6 col-sm-12">                            <select class="form-select" id="physicianSelect" aria-label="Floating label select example">                               <option selected>Select Physician</option>                               <option>Select 1</option>                               <option>Select 2</option>                               <option>Select 3</option>                               <option>Select 4</option>                            </select>                        </div>                    </div>                    <div class="d-flex justify-content-end gap-3">                        <button type="submit" id="submitBtn" class="btn btn-info text-white EditBtn">Submit </button>                        <button type="button" id="cancelBtn" class="btn btn-outline-info EditBtn">Cancel</button>                    </div>                </div>                </div>            </div>        </div></form>