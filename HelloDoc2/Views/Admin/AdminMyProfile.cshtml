@model DAL.ViewModel.AdminProfileVm;
@{
    Layout = "~/Views/Shared/_LayoutMainAdminDashboard.cshtml";
}

<div class="bg-body-tertiary ">
    <div class="container">

        @*Page Header*@
        <div class="d-flex justify-content-between">
            <h2 class="mt-3 mb-4"> My Profile </h2>
            <a asp-controller="Admin" asp-action="AdminDashboard">
                <span type="button" class="btn btn-outline-primary border-info text-info mt-3 mb-4 ">&lt; Back</span>
            </a>
        </div>

        @*Main Section*@
        <div class="shadow bg-white rounded-3 p-4">

            @*First div*@
            <h3 class="">Account Information</h3>

            <div class="row g-2">

                @*Username*@
                <div class="form-floating mb-3 col-sm-12 col-md-6 col-lg-6 col-xl-6 d-flex">
                    <input type="text" class="form-control bg-transparent" id="pi_name" placeholder="username">
                    <label>Username</label>
                </div>

                @*Password*@
                <div class="form-floating mb-3 col-sm-12 col-md-6 col-lg-6 col-xl-6 d-flex">
                    <input type="text" class="form-control bg-transparent" id="pi_name" placeholder="password">
                    <label>Password</label>
                </div>

                @*Status*@
                <div class="form-floating mb-3 col-sm-12 col-md-6 col-lg-6 col-xl-6 d-flex">
                    <select class="form-select" aria-label="Default select example">
                        <option selected>Active</option>
                        <option value="1">Leave</option>
                        <option value="2">Retired</option>
                    </select>
                    <label>Status</label>
                </div>

                @*Role*@

                <div class="form-floating mb-3 col-sm-12 col-md-6 col-lg-6 col-xl-6 d-flex">
                    <select class="form-select" aria-label="Default select example">
                        <option selected>Master Admin</option>
                        <option value="1">Admin</option>
                    </select>
                    <label>Role</label>
                </div>

                @*Reset Password*@
                <div class="d-flex justify-content-end">
                    <a>
                        <span type="button" class="btn btn-outline-primary border-info text-info my-2">Reset Password</span>
                    </a>
                </div>

            </div>


            @*Second Div*@
            <h3>Administrator Information</h3>

            <div class="row g-2">

                @*Firstnanme*@
                <div class="form-floating mb-3 col-sm-12 col-md-6 col-lg-6 col-xl-6 d-flex">
                    <input type="text" class="form-control bg-transparent" id="pi_name" placeholder="firstname">
                    <label>First Name</label>
                </div>

                @*Lastname*@
                <div class="form-floating mb-3 col-sm-12 col-md-6 col-lg-6 col-xl-6 d-flex">
                    <input type="text" class="form-control bg-transparent" id="pi_name" placeholder="lastname">
                    <label>Last Name</label>
                </div>

                @*Email*@
                <div class="form-floating mb-3 col-sm-12 col-md-6 col-lg-6 col-xl-6 d-flex">
                    <input type="text" class="form-control bg-transparent" id="pi_name" placeholder="firstname">
                    <label>Email</label>
                </div>

                @*Confirm Email*@
                <div class="form-floating mb-3 col-sm-12 col-md-6 col-lg-6 col-xl-6 d-flex">
                    <input type="text" class="form-control bg-transparent" id="pi_name" placeholder="firstname">
                    <label>Confirm Email</label>
                </div>


                @*Phone*@
                <div class="form-floating mb-3 col-sm-12 col-md-6 col-lg-6 col-xl-6 d-flex">
                    <input type="text" class="form-control bg-transparent" id="pi_name" placeholder="firstname">
                    <label>Phone</label>
                </div>

                <div class="form-floating mb-3 col-sm-12 col-md-6 col-lg-6 col-xl-6 d-flex">
                    <div class="form-check form-check-inline fs-5 p-3 mx-3">
                        <input class="form-check-input" type="checkbox" id="inlineCheckbox1" value="option1">
                        <label class="form-check-label" for="inlineCheckbox1">Gujarat</label>
                    </div>
                    <div class="form-check form-check-inline fs-5 p-3 mx-3">
                        <input class="form-check-input" type="checkbox" id="inlineCheckbox1" value="option1">
                        <label class="form-check-label" for="inlineCheckbox1">Rajasthan</label>
                    </div>
                    <div class="form-check form-check-inline fs-5 p-3 mx-3">
                        <input class="form-check-input" type="checkbox" id="inlineCheckbox1" value="option1">
                        <label class="form-check-label" for="inlineCheckbox1">Goa</label>
                    </div>
                    <div class="form-check form-check-inline fs-5 p-3 mx-3">
                        <input class="form-check-input" type="checkbox" id="inlineCheckbox1" value="option1">
                        <label class="form-check-label" for="inlineCheckbox1">Delhi</label>
                    </div>
                </div>

                @*Reset Password*@
                <div class="d-flex justify-content-end">
                    <a>
                        <span type="button" class="btn btn-info text-white p-2 px-3">Edit</span>
                    </a>
                </div>

            </div>



            @*Third Div*@
            <h3>Mailing & Billing Information</h3>

            <div class="row g-2">

                @*Address*@
                <div class="form-floating mb-3 col-sm-12 col-md-6 col-lg-6 col-xl-6 d-flex">
                    <input type="text" class="form-control bg-transparent" id="pi_name" placeholder="firstname">
                    <label>Address #1</label>
                </div>

                @*Address*@
                <div class="form-floating mb-3 col-sm-12 col-md-6 col-lg-6 col-xl-6 d-flex">
                    <input type="text" class="form-control bg-transparent" id="pi_name" placeholder="lastname">
                    <label>Address #2</label>
                </div>

                @*City*@
                <div class="form-floating mb-3 col-sm-12 col-md-6 col-lg-6 col-xl-6 d-flex">
                    <input type="text" class="form-control bg-transparent" id="pi_name" placeholder="firstname">
                    <label>City</label>
                </div>

                @*State*@
                <div class="form-floating mb-3 col-sm-12 col-md-6 col-lg-6 col-xl-6 d-flex">
                    <input type="text" class="form-control bg-transparent" id="pi_name" placeholder="firstname">
                    <label>State</label>
                </div>

                @*Zip*@
                <div class="form-floating mb-3 col-sm-12 col-md-6 col-lg-6 col-xl-6 d-flex">
                    <input type="text" class="form-control bg-transparent" id="pi_name" placeholder="firstname">
                    <label>Zip</label>
                </div>

                @*Phone*@
                <div class="form-floating mb-3 col-sm-12 col-md-6 col-lg-6 col-xl-6 d-flex">
                    <input type="text" class="form-control bg-transparent" id="pi_name" placeholder="firstname">
                    <label>Phone</label>
                </div>

                @*Reset Password*@
                <div class="d-flex justify-content-end">
                    <a>
                        <span type="button" class="btn btn-info text-white p-2 px-3">Edit</span>
                    </a>
                </div>

            </div>

        </div>
    </div>
</div>
