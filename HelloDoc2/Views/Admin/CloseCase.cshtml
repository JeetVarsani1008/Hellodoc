@{    Layout = "~/Views/Shared/_LayoutMainAdminDashboard.cshtml";}@model DAL.ViewModel.CloseCaseVm;<div class="container d-flex flex-column gap-2 p-3 ">    <div class="heading">        <div class="d-flex justify-content-between align-items-center fw-bold mt-5">            <h4>Close Case</h4>            <a asp-controller="Admin" asp-action="AdminDashboard" class="btn shadow  btn-outline-secondary border-info text-info px-3 ">              Back            </a>        </div>    </div>    <div class="shadow border rounded my-3 fw-bold">        <div class="mx-3 my-4">            <div class="d-flex justify-content-between">                <div>                    <div class="text-secondary">Patient Name  </div>                    <div class="d-flex flex-column flex-lg-row align-items-left ">                        <span class="fw-bolder fs-5 text-info">ViewBag.Username</span>                        <span class="fs-6 mt-1">(MD05122486257)</span>                    </div>                </div>                <button type="button" class="btn btn-outline-info" id="createinvoicebtn">Create Invoice Through Quickbooks</button>            </div>            <div class="d-flex justify-content-between mt-2">                <div class="fs-4 fw-bolder mt-2">Documents</div>            </div>        </div>        <table class="table">            <tbody>                                    <tr style="background-color: rgba(160, 160, 160, 0.137) !important">                    <td width="60%" style="background-color: rgba(160, 160, 160, 0.137) !important"></td>                    <td width="30%" style="background-color: rgba(160, 160, 160, 0.137) !important">Upload Date &nbsp;<i class="fa fa-arrow-up" aria-hidden="true"></i></td>                    <td width="10%" style="background-color: rgba(160, 160, 160, 0.137) !important">Actions</td>                </tr>                                <tr>                        <td><i class="bi bi-file-earmark-pdf-fill text-danger  ms-3 me-2" style="font-size:1.25rem"></i><span class="fs-6">item.Filename</span></td>                        <td>item.Createddate.ToString("MMM dd, yyyy")</td>                    <td>                            <a download href="~/Uplods/item.Filename" class="btn-outline-secondary border-info text-info">   <i class="bi bi-cloud-arrow-down-fill "></i></a>                    </td>                </tr>                            </tbody>        </table>       @* <div class="documentsdata">            <hr />            <div style="margin-bottom: 10px; margin-top: 10px;">                <span style=" font-size: 14px;"><i class="bi bi-filetype-pdf ml-2" style="color: red; font-size: 20px; margin-left: 5px;"></i>&nbsp;&nbsp;</span>            </div>            <div style="margin-bottom: 10px; font-size: 13px;">            </div>            <div style="margin-bottom: 10px; font-size: 13px;">            </div>            <div style="margin-bottom: 20px !important;">                <a href="/Admin/Downloadfile/" class="btn6" style="padding: 7px;"><i class="bi bi-cloud-arrow-up upsmall" style="font-size: 15px;"></i></a>                <a href="#" class="btn6" style="padding: 7px;"><i class="bi bi-trash3 upsmall"></i></a>            </div>            <hr>        </div>*@        <form asp-action="AdminEditCloseCase" asp-controller="Admin"  method="post">            <div class="row mt-4  m-2 fw-normal">                <h4 class="fw-bold">Patient Information</h4>                <input type="hidden" value="Model.RequestId" id="id" />                <div class=" col-md-6 mb-2 mt-3">                    <div class="form-floating">                        <input type="text" class="form-control" value="Model.FirstName" asp-for="FirstName" id="floatingInput" placeholder="First Name" readonly>                        <label for="floatingInput">First Name</label>                    </div>                </div>                <div class=" col-md-6 mt-3">                    <div class="form-floating mb-2">                        <input type="text" class="form-control" id="floatingInput" value="Model.LastName" asp-for="LastName" placeholder="Last Name" readonly>                        <label for="floatingInput">Last Name</label>                    </div>                </div>                <div class="col-md-6 mt-2">                    <div class="form-floating mb-2">                        <input type="date" class="form-control" id="floatingInput" value="Model.DateOfBirth" asp-for=DateOfBirth style="font-size: 15px;" readonly>                        <label for="floatingInput">Date Of Birth</label>                    </div>                </div>                <div class="col-lg-5 col-md-4 col-sm-10 col-10 mt-2">                    <div class="form-floating mb-2">                        <input type="text" name="phonenumber" class="form-control enabled"  id="Phone" readonly>                        <label for="Emailforlogin">Phone Number</label>                    </div>                </div>                <div class="col-md-2 col-lg-1 col-sm-2 col-2 mt-2">                    <div class="btn btn-outline-info d-flex justify-content-center align-items-center" style="height: 3.7rem;width: 100% !important;" readonly>                        <i class="bi bi-telephone-fill" style="font-size: 20px;"></i>                    </div>                </div>                <div class=" col-md-6 mt-2">                    <div class="form-floating">                        <input type="email" class="form-control enabled" id="CLoseCaseemail" placeholder="name@example.com" readonly>                        <label for="Emailforlogin">Email</label>                    </div>                </div>                <div class="col-12 mt-4 d-flex justify-content-end mb-4" >                    <button type="button" class="btn btn-info me-2" id="closecaseeditbtn">Edit</button>                    <button type="submit" name="command" value="2" class="btn btn-outline-info" id="closebtn">Close Case</button>                    <a type="button" name="command" value="1" class="btn btn-info me-2" id="closecasesavebtn"  style="display: none;">Save</a>                    <a href="#" type="button" class="btn btn-outline-info" id="closecasecancelbtn" style=" display: none;">Cancel</a>                </div>            </div>        </form>    </div></div><script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script><script>    $(document).ready(function () {        // Click event handler for the "Edit" button        $('#closecaseeditbtn').click(function (e) {            e.preventDefault(); // Prevent default action            // Remove the readonly attribute from the email and phone fields            $('#CLoseCaseemail, #Phone').removeAttr('readonly');            // Show the "Save" and "Cancel" buttons, hide the "Edit" and "Close Case" buttons            $('#closecaseeditbtn, #closebtn').hide();            $('#closecasesavebtn, #closecasecancelbtn').show();        });        // Click event handler for the "Close Case" button               // Click event handler for the "Save" button        $('#closecasesavebtn').click(function (e) {            e.preventDefault(); // Prevent default form submission            // Get the email, Phone, and id values            var email = $('#CLoseCaseemail').val();            var phone = $('#Phone').val();            var id = $('#id').val();            // Make an AJAX call to the controller method            $.ajax({                url: '/Admin/EditCloseCase', // Change the URL to your actual controller method                method: 'POST', // Use POST method to send data                data: {                    email: email,                    phone: phone,                    id: id                },                success: function (response) {                    // Handle success response                    console.log(response);                    // You can display a success message or perform any other actions here                },                error: function (xhr, status, error) {                    // Handle error                    console.error(xhr.responseText);                    // You can display an error message or perform any other actions here                }            });            // Add the readonly attribute back to the email and phone fields            $('#CLoseCaseemail, #Phone').attr('readonly', true);            // Show the "Edit" and "Close Case" buttons, hide the "Save" and "Cancel" buttons            $('#closecaseeditbtn, #closebtn').show();            $('#closecasesavebtn, #closecasecancelbtn').hide();        });        // Click event handler for the "Cancel" button        $('#closecasecancelbtn').click(function (e) {            e.preventDefault(); // Prevent default action            // Add the readonly attribute back to the email and phone fields            $('#CLoseCaseemail, #Phone').attr('readonly', true);            // Show the "Edit" and "Close Case" buttons, hide the "Save" and "Cancel" buttons            $('#closecaseeditbtn, #closebtn').show();            $('#closecasesavebtn, #closecasecancelbtn').hide();        });    });</script><script>    function Checkemail() {        $("#Status").html("Checking...");        $.post("@Url.Action("Checkemail", "Home")",            {                userdata: $("#CLoseCaseemail").val()            },            function (data) {                if (data == 1) {                    $("#Status").html('<span style="color: green;">This mail already existed</span>')                    $("#AEmail").css("border-color", "green");                }                else {                    $("#Status").html('<span style="color: blue;">continue</span>')                    $("#AEmail").css("border-color", "blue");                }            }        );    }</script>